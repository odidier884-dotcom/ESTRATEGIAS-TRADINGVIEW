//@version=5
strategy("Institutional Quant ML Strategy", overlay=true, initial_capital=10000)

//----------------------------------------------------
// INPUTS
//----------------------------------------------------

training = input.int(150,"Training Window")
neighbors = input.int(9,"KNN Neighbors")

//----------------------------------------------------
// INDICADORES
//----------------------------------------------------

rsi = ta.rsi(close,14)
mfi = ta.mfi(hlc3,14)

momentum = close - close[10]
volatility = ta.stdev(close,20)

trend = ta.sma(close,200)

//----------------------------------------------------
// NORMALIZACION
//----------------------------------------------------

nRSI = (rsi-50)/50
nMFI = (mfi-50)/50
nMom = momentum/close
nVol = volatility/close

//----------------------------------------------------
// KNN MACHINE LEARNING
//----------------------------------------------------

var float vote = 0
vote := 0

for i = 20 to training

    pRSI = (ta.rsi(close[i],14)-50)/50
    pMFI = (ta.mfi(hlc3[i],14)-50)/50
    pMom = (close[i]-close[i+10])/close[i]
    pVol = ta.stdev(close[i],20)/close[i]

    distance =
         math.pow(nRSI-pRSI,2) +
         math.pow(nMFI-pMFI,2) +
         math.pow(nMom-pMom,2) +
         math.pow(nVol-pVol,2)

    label = close[i-1] > close[i] ? 1 : -1

    vote += label/(1+distance)

//----------------------------------------------------
// PROBABILIDAD
//----------------------------------------------------

prob = 1/(1+math.exp(-vote))

//----------------------------------------------------
// MONTE CARLO
//----------------------------------------------------

ret = math.log(close/close[1])

mu = ta.sma(ret,30)
sigma = ta.stdev(ret,30)

mcUp = close * math.exp(mu + sigma)
mcDown = close * math.exp(mu - sigma)

bullMC = mcUp > close
bearMC = mcDown < close

//----------------------------------------------------
// REGIMEN DE MERCADO
//----------------------------------------------------

bullTrend = close > trend
bearTrend = close < trend

//----------------------------------------------------
// FILTRO DE VOLUMEN INSTITUCIONAL
//----------------------------------------------------

volMA = ta.sma(volume,30)

institutionalFlow = volume > volMA

//----------------------------------------------------
// SEÑALES
//----------------------------------------------------

buySignal =
 prob > 0.58 and
 bullTrend and
 bullMC and
 institutionalFlow

sellSignal =
 prob < 0.42 and
 bearTrend and
 bearMC and
 institutionalFlow

//----------------------------------------------------
// EJECUCION
//----------------------------------------------------

if buySignal
    strategy.entry("LONG",strategy.long)

if sellSignal
    strategy.entry("SHORT",strategy.short)

//----------------------------------------------------
// RISK MANAGEMENT
//----------------------------------------------------

atr = ta.atr(14)

takeProfit = atr*3
stopLoss = atr*1.4

strategy.exit("TP LONG","LONG",profit=takeProfit,loss=stopLoss)
strategy.exit("TP SHORT","SHORT",profit=takeProfit,loss=stopLoss)

//----------------------------------------------------
// PLOTS
//----------------------------------------------------

plot(prob,title="ML Probability",color=color.green)

plot(trend,title="MA 200",color=color.red)

plot(rsi,title="RSI",color=color.blue)
plot(mfi,title="MFI",color=color.orange)
