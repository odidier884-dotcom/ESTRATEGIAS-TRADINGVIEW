//@version=5
strategy("Fibonacci + Monte Carlo PRO Strategy", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// ===== Parámetros =====
daysBack = input.int(60, "Días hacia atrás")
simulations = input.int(100, "Simulaciones")
daysAhead = input.int(10, "Días proyectados")
sl_pct = input.float(1.5, "Stop Loss %") / 100
tp_pct = input.float(3.0, "Take Profit %") / 100
probThreshold = input.float(0.6, "Probabilidad mínima")

// ===== Fibonacci 50% =====
highestPrice = ta.highest(high, daysBack)
lowestPrice = ta.lowest(low, daysBack)
f50 = highestPrice - (highestPrice - lowestPrice) * 0.5

// ===== Señal base =====
baseBuy = close < f50

// ===== Retornos =====
ret = math.log(close / close[1])
mu = ta.sma(ret, daysBack)
sigma = ta.stdev(ret, daysBack)

// ===== Monte Carlo =====
tp_hits = 0
sl_hits = 0

takeProfit = baseBuy ? close * (1 + tp_pct) : close * (1 - tp_pct)
stopLoss = baseBuy ? close * (1 - sl_pct) : close * (1 + sl_pct)

for i = 0 to simulations - 1
    priceSim = close
    tpHit = false
    slHit = false
    
    for d = 0 to daysAhead - 1
        rand = math.random(-1.0, 1.0)
        simReturn = mu + sigma * rand
        priceSim := priceSim * math.exp(simReturn)
        
        if not tpHit and not slHit
            if baseBuy and priceSim >= takeProfit
                tpHit := true
            if baseBuy and priceSim <= stopLoss
                slHit := true
            if not baseBuy and priceSim <= takeProfit
                tpHit := true
            if not baseBuy and priceSim >= stopLoss
                slHit := true
    
    if tpHit
        tp_hits += 1
    if slHit
        sl_hits += 1

probTP = tp_hits / simulations
probSL = sl_hits / simulations

// ===== Inversión automática =====
finalBuy = baseBuy
if probSL > probTP and probSL > probThreshold
    finalBuy := not baseBuy

// ===== Señales =====
buySignal = finalBuy and not finalBuy[1]
sellSignal = not finalBuy and finalBuy[1]

// ===== Estrategia =====
if buySignal
    strategy.entry("Long", strategy.long)

if sellSignal
    strategy.entry("Short", strategy.short)

// ===== Stop Loss y Take Profit =====
longStop = strategy.position_avg_price * (1 - sl_pct)
longTP = strategy.position_avg_price * (1 + tp_pct)

shortStop = strategy.position_avg_price * (1 + sl_pct)
shortTP = strategy.position_avg_price * (1 - tp_pct)

strategy.exit("Exit Long", from_entry="Long", stop=longStop, limit=longTP)
strategy.exit("Exit Short", from_entry="Short", stop=shortStop, limit=shortTP)

// ===== Visual =====
plotshape(buySignal, style=shape.triangleup, location=location.belowbar, size=size.large, color=color.lime)
plotshape(sellSignal, style=shape.triangledown, location=location.abovebar, size=size.large, color=color.red)

// ===== Panel =====
var table panel = table.new(position.top_right, 1, 3)

if barstate.islast
    table.cell(panel, 0, 0, "Prob TP: " + str.tostring(probTP*100, "#.##") + "%")
    table.cell(panel, 0, 1, "Prob SL: " + str.tostring(probSL*100, "#.##") + "%")
    table.cell(panel, 0, 2, "Precio: " + str.tostring(close, "#.##"))
